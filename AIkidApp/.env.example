# Public StoryMee Gateway (storymee-hub) — BẮT BUỘC domain public
# Auth → /api/v1/account/* → core-account-api (via hub)
# Không hardcode IP LAN trên client
EXPO_PUBLIC_API_URL=https://dev-hub.storymee.com

# Fallback ipId khi workspace discovery fail (dev)
EXPO_PUBLIC_DEFAULT_IP_ID=11111111-1111-1111-1111-111111111111

# Auth mode: family (parent + child profiles, default) | parent_only | guest
EXPO_PUBLIC_AUTH_MODE=family

# Firebase dual-auth is opt-in. Never put Admin service-account JSON here.
EXPO_PUBLIC_FIREBASE_AUTH_ENABLED=false
EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=

# Legal
EXPO_PUBLIC_PRIVACY_URL=https://aikids.storymee.com/privacy
EXPO_PUBLIC_TERMS_URL=https://aikids.storymee.com/terms
EXPO_PUBLIC_DELETE_ACCOUNT_URL=https://aikids.storymee.com/account/delete
EXPO_PUBLIC_SUPPORT_EMAIL=storymee.com@gmail.com
